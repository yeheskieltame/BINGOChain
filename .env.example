# --- Celo Sepolia (primary dev/staging target) -----------------------------
# BINGOChain contracts are built and deployed on Sepolia first; a single key is
# fine here (testnet only).
CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org/
DEPLOYER_PRIVATE_KEY=0x...
DEPLOYER_ADDRESS=0x...

# Initial owner / treasury for the proxy initializer. On Sepolia these may all
# equal the deployer; on mainnet the owner must be a Safe multisig.
OWNER_ADDRESS=
TREASURY_ADDRESS=
PROTOCOL_FEE_BPS=100

# --- Celo Mainnet (production, later) ---------------------------------------
CELO_MAINNET_RPC=https://forno.celo.org

# --- Verification -----------------------------------------------------------
# Unified Etherscan API V2 key — works for Celo + 60+ other EVM chains.
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Faucet for Sepolia CELO: https://faucet.celo.org/celo-sepolia
