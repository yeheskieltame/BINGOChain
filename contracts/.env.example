# --- Celo Mainnet (the only target) ----------------------------------------
CELO_MAINNET_RPC=https://forno.celo.org

# Deployer (pays gas). On mainnet the owner MUST differ from the deployer, so the
# upgrade key is not the hot deploy key (Deploy.s.sol enforces this on chain 42220).
DEPLOYER_PRIVATE_KEY=0x...
DEPLOYER_ADDRESS=0x...

# Initial owner (a Safe multisig) and treasury for the proxy initializer.
OWNER_ADDRESS=
TREASURY_ADDRESS=
PROTOCOL_FEE_BPS=100

# --- Verification -----------------------------------------------------------
# Unified Etherscan API V2 key — works for Celo + 60+ other EVM chains.
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Note: this project is mainnet-only. For safe local testing, fork mainnet with
# anvil (`anvil --fork-url $CELO_MAINNET_RPC`) instead of using a public testnet.
